#!/bin/sh

DEP_ROOT=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd -P)

main()(
  for f in "$DEP_ROOT"/commands/*.sh; do
    . "$f"
  done

  while true; do
    case "${1:-}" in
      global)  DEP_GLOBAL=1; shift ;;
      --trust) DEP_AUTO_TRUST=1; shift ;;
      *) break ;;
    esac
  done

  case "${1:-}" in
    --version|-v) echo "dep $DEP_VERSION"; return 0 ;;
  esac

  task="${1:-help}"
  shift 2>/dev/null || true

  cmd="dep_$task"
  if command -v "$cmd" >/dev/null 2>&1; then
    "$cmd" "$@"
    return
  fi

  root=$(dep_find_root 2>/dev/null) || { dep_help; return; }
  scripts_path=$(dep_scripts_path "$root")

  if dep_script_has_user_task "$scripts_path" "$task"; then
    dep_run_user_task "$root" "$scripts_path" "$task" "$@"
    return
  fi

  matches=$(dep_dep_user_task_matches "$root" "$task")
  if test -n "$matches"; then
    count=0
    # Nom au pluriel conservé volontairement : on sélectionne un script parmi
    # l'ensemble des fichiers @scripts potentiellement exposés par les deps.
    selected_scripts=""

    nl='
'
    old_ifs=$IFS
    IFS=$nl
    set -f
    for match in $matches; do
      test -n "$match" || continue
      eval "$match"
      count=$((count + 1))
      test -n "$selected_scripts" || selected_scripts="$dep_scripts_path"
      if test "$count" -gt 1; then
        break
      fi
    done
    set +f
    IFS=$old_ifs

    if test "$count" -gt 1; then
      echo "tâche ambiguë: $task"
      printf '%s\n' "$matches" | while IFS= read -r match; do
        test -n "$match" || continue
        eval "$match"
        printf '  %s (%s)\n' "$task" "$dep_name"
      done
      return 1
    fi

    dep_run_user_task "$root" "$selected_scripts" "$task" "$@"
    return
  fi

  dep_help
  return 1 # Commande non trouvee
)

main "$@"
